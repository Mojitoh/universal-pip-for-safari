{
  "manifest_version": 3,
  "name": "Universal PiP for Safari",
  "version": "0.1.2",
  "description": "Adds a Picture in Picture button to HTML5 video players in Safari.",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_title": "Toggle Picture in Picture",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_page": "options.html",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "Alt+P"
      },
      "description": "Toggle Picture in Picture for the best video on the page"
    }
  }
}
